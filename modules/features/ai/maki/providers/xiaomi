#!/usr/bin/env bash
# Dynamic Xiaomi MiMo provider for maki.
# Uses XIAOMI_MIMO_API_KEY env var.
#
# Subcommands: info, resolve, models

set -euo pipefail

API_URL="https://api.xiaomi.com/v1"

case "${1:-}" in
info)
  cat <<'JSON'
{
  "display_name": "Xiaomi MiMo",
  "base": "openai",
  "has_auth": true
}
JSON
  ;;
resolve)
  if [ -z "${XIAOMI_MIMO_API_KEY:-}" ]; then
    echo '{"error": "XIAOMI_MIMO_API_KEY not set in environment"}' >&2
    exit 1
  fi
  jq -n --arg key "$XIAOMI_MIMO_API_KEY" --arg url "$API_URL" '{
    base_url: $url,
    headers: { Authorization: "Bearer \($key)" }
  }'
  ;;
models)
  cat <<'JSON'
[
  {
    "id": "mimo-v2.5-pro",
    "name": "MiMo V2.5 Pro",
    "tier": "strong",
    "context_window": 1000000,
    "max_output_tokens": 131072,
    "reasoning": true
  },
  {
    "id": "mimo-v2.5",
    "name": "MiMo V2.5",
    "tier": "medium",
    "context_window": 1000000,
    "max_output_tokens": 131072,
    "reasoning": true
  }
]
JSON
  ;;
*)
  echo "Usage: ${0##*/} {info|resolve|models}" >&2
  exit 1
  ;;
esac
