#!/usr/bin/env bash
# Dynamic DeepSeek provider for maki.
# Uses DEEPSEEK_API_KEY env var. Overrides built-in tier defaults.
#
# Subcommands: info, resolve, models

set -euo pipefail

API_URL="https://api.deepseek.com"

case "${1:-}" in
info)
  cat <<'JSON'
{
  "display_name": "DeepSeek (custom tiers)",
  "base": "deepseek",
  "has_auth": true
}
JSON
  ;;
resolve)
  if [ -z "${DEEPSEEK_API_KEY:-}" ]; then
    echo '{"error": "DEEPSEEK_API_KEY not set in environment"}' >&2
    exit 1
  fi
  jq -n --arg key "$DEEPSEEK_API_KEY" --arg url "$API_URL" '{
    base_url: $url,
    headers: { Authorization: "Bearer \($key)" }
  }'
  ;;
models)
  cat <<'JSON'
[
  {
    "id": "deepseek-v4-flash",
    "name": "DeepSeek V4 Flash",
    "tier": "weak",
    "context_window": 1000000,
    "max_output_tokens": 384000
  },
  {
    "id": "deepseek-v4-pro",
    "name": "DeepSeek V4 Pro",
    "tier": "medium",
    "context_window": 1000000,
    "max_output_tokens": 384000
  },
  {
    "id": "deepseek-v4-pro",
    "name": "DeepSeek V4 Pro",
    "tier": "strong",
    "context_window": 1000000,
    "max_output_tokens": 384000
  }
]
JSON
  ;;
*)
  echo "Usage: ${0##*/} {info|resolve|models}" >&2
  exit 1
  ;;
esac
